<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\u21BB Reajustar Valor da Corrida"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A2C3E"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvAdjRideInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#5E6F8D"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvAdjDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#9CA3AF"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvAdjTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#9CA3AF"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Novo valor real:"
        android:textSize="13sp"
        android:textColor="#333333"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etAdjValue"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:inputType="numberDecimal"
        android:hint="R$ 20,00"
        android:textSize="16sp"
        android:textColor="#1A1A2E"
        android:background="@drawable/pill_unselected"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Motivo (opcional):"
        android:textSize="13sp"
        android:textColor="#333333"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etAdjReason"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:inputType="text"
        android:hint="Ex: Trânsito, desvio..."
        android:textSize="14sp"
        android:textColor="#1A1A2E"
        android:background="@drawable/pill_unselected"
        android:paddingHorizontal="12dp" />

</LinearLayout>
