<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/card_padding"
            android:paddingTop="@dimen/card_padding"
            android:paddingBottom="@dimen/card_padding">

            <include layout="@layout/toolbar_default" />

            <!-- HERO — Meta sugerida -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_header_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="META SUGERIDA"
                        android:textSize="@dimen/text_size_10"
                        android:textStyle="normal"
                        android:textColor="@color/overlay_text_secondary"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvSuggestedGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- km/m\u00eas"
                        android:textSize="@dimen/text_size_48"
                        android:textStyle="bold"
                        android:textColor="@color/success"
                        android:letterSpacing="-0.02"
                        android:layout_marginBottom="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/overlay_border"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvGoalDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Baseado na m\u00e9dia dos \u00faltimos 3 meses"
                        android:textSize="@dimen/text_size_12"
                        android:textColor="@color/overlay_text_secondary"
                        android:letterSpacing="0.01" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- SEÇÃO: Análise Mensal -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AN\u00c1LISE MENSAL"
                android:textSize="@dimen/text_size_10"
                android:textStyle="normal"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <!-- Card: KM por Mês -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KM por M\u00eas"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:id="@+id/kmGraphContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nenhum dado dispon\u00edvel"
                            android:textSize="@dimen/text_size_12"
                            android:textColor="@color/text_tertiary"
                            android:gravity="center"
                            android:paddingVertical="24dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card: Custo Combustível por Mês -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Custo Combust\u00edvel por M\u00eas"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:id="@+id/fuelGraphContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nenhum dado dispon\u00edvel"
                            android:textSize="@dimen/text_size_12"
                            android:textColor="@color/text_tertiary"
                            android:gravity="center"
                            android:paddingVertical="24dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- SEÇÃO: Dados Brutos -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DADOS BRUTOS"
                android:textSize="@dimen/text_size_10"
                android:textStyle="normal"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <!-- Card: Tabela -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Cabeçalho do card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/card_padding"
                        android:paddingTop="@dimen/card_padding"
                        android:paddingBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KM por M\u00eas"
                            android:textSize="@dimen/text_size_14"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <!-- Cabeçalho da tabela -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/bg_surface"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="@dimen/card_padding">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="M\u00caS/ANO"
                            android:textSize="@dimen/text_size_9"
                            android:textStyle="normal"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="KM"
                            android:textSize="@dimen/text_size_9"
                            android:textStyle="normal"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.06"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="COMBUST\u00cdVEL"
                            android:textSize="@dimen/text_size_9"
                            android:textStyle="normal"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.06"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.8"
                            android:text="CONSUMO"
                            android:textSize="@dimen/text_size_9"
                            android:textStyle="normal"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.06"
                            android:gravity="end" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border" />

                    <LinearLayout
                        android:id="@+id/statsTableContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/card_padding"
                        android:paddingVertical="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nenhum dado dispon\u00edvel"
                            android:textSize="@dimen/text_size_12"
                            android:textColor="@color/text_tertiary"
                            android:gravity="center"
                            android:paddingVertical="20dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <include layout="@layout/bottom_nav" />

</LinearLayout>
