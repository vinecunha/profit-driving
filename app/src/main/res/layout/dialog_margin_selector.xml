<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvCostInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1A2C3E"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MÍNIMO (cor vermelha)"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#F87171"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/radioGroupMin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IDEAL (cor verde)"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#4ADE80"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/radioGroupIdeal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ O valor MÍNIMO deve ser menor que o IDEAL"
        android:textSize="12sp"
        android:textColor="#F97316"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

</LinearLayout>
