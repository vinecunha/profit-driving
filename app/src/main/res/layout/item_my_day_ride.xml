<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootRideCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/inner_card_bg"
    android:padding="12dp"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/chkCompleted"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="\u2610"
            android:textSize="18sp"
            android:textColor="#5E6F8D"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvRideTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#5E6F8D"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvRideService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#5E6F8D" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvRideOriginalValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvRideExtras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#00A86B"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvRideFinalValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#00A86B" />

            <TextView
                android:id="@+id/tvExpandHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\u25BC"
                android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutRideDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        android:paddingTop="8dp"
        android:background="#F0F2F8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="\uD83D\uDCCD Embarque:"
                android:textSize="11sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvDetailPickup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#1A2C3E"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="\uD83C\uDFC1 Viagem:"
                android:textSize="11sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvDetailTrip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#1A2C3E"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:background="#E8ECF4"
            android:layout_marginHorizontal="4dp"
            android:layout_marginVertical="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="\uD83D\uDCCD Total:"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1A2C3E" />

            <TextView
                android:id="@+id/tvDetailTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1A2C3E" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E9F0"
            android:layout_marginVertical="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="\uD83D\uDCB0 Valor base:"
                android:textSize="11sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvDetailBaseValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#1A2C3E"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutDetailTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="\uD83C\uDF6F Gorjeta:"
                android:textSize="11sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvDetailTip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#00A86B"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutDetailAdjust"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="\uD83D\uDD04 Reajuste:"
                android:textSize="11sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvDetailAdjust"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#F97316"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="\uD83D\uDCB5 Total corrida:"
                android:textSize="11sp"
                android:textColor="#1A2C3E"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailFinalValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1A2C3E" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="\uD83D\uDCC9 Custo:"
                android:textSize="11sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvDetailCost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#EF4444"
                android:textStyle="bold" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E9F0"
            android:layout_marginVertical="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lucro:"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A2C3E" />

            <TextView
                android:id="@+id/tvDetailProfit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#00A86B" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvDetailProfitPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#9CA3AF"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="4dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:paddingHorizontal="10dp"
            android:gravity="center"
            android:text="\u21BA Remover"
            android:textSize="11sp"
            android:textColor="#F44336"
            android:textStyle="bold"
            android:background="@drawable/pill_unselected"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnCancelWithFee"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:paddingHorizontal="10dp"
            android:gravity="center"
            android:text="\uD83D\uDEAB Cancelar"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/pill_selected"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/btnAddTip"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:paddingHorizontal="10dp"
            android:gravity="center"
            android:text="+ Gorjeta"
            android:textSize="11sp"
            android:textColor="#00982B"
            android:textStyle="bold"
            android:background="@drawable/pill_unselected"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/btnAdjust"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:paddingHorizontal="10dp"
            android:gravity="center"
            android:text="\u21BB Reajustar"
            android:textSize="11sp"
            android:textColor="#F97316"
            android:textStyle="bold"
            android:background="@drawable/pill_unselected"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
