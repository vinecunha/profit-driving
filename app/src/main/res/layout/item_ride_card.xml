<?xml version="1.0" encoding="utf-8"?>
<!--
  CorridaCerta — item_ride_card (redesign)
  =========================================
  Prompt para o OpenCode:

  Substitua o arquivo `res/layout/item_ride_card.xml` pelo conteúdo abaixo.
  Não altere nenhum android:id existente — apenas a estrutura visual e os
  atributos de aparência (tamanhos, margens, backgrounds, cores, gravity).
  Não toque em nenhum arquivo .kt/.java.

  Novos drawables necessários (criar se não existirem):
    - bg_ride_card_top_dark   → shape retangular, fillColor="@color/card_header_dark", cornerRadii apenas nos cantos superiores (topLeftRadius="@dimen/inner_corner_radius", topRightRadius="@dimen/inner_corner_radius") — usa o mesmo raio do CardView para casar visualmente
    - bg_decision_accept      → shape retangular, fillColor="@color/success", cornerRadius="@dimen/pill_corner_radius"
    - bg_decision_decline     → shape retangular, fillColor="@color/error", cornerRadius="@dimen/pill_corner_radius"
    - bg_metric_cell          → shape retangular, fillColor="@color/bg_surface", cornerRadius="@dimen/badge_corner_radius"
    - bg_bonus_pill_dark      → shape retangular, fillColor="#26200A", strokeColor="#614A10", strokeWidth="1dp", cornerRadius="@dimen/pill_corner_radius"
    - bg_score_pill           → shape retangular, fillColor="@color/bg_surface", cornerRadius="@dimen/pill_corner_radius"

  Ajustes de "tom moderno/profissional" aplicados neste redesign, usando os
  tokens já existentes em values/ (nada de hex ou dp soltos novos):
    - Card todo arredondado com @dimen/card_corner_radius (em vez de cantos
      retos) — elimina a dissonância entre o card e o header arredondado só
      no topo. Elevação volta a usar @dimen/card_elevation (token padrão).
    - Padding de header e corpo usando @dimen/card_padding (token padrão do
      design system) ao invés de valores soltos (18, 14, 16dp variados).
    - Labels secundários (EMBARQUE, DESTINO, Total, R$/KM, R$/H, R$/MIN)
      deixam de ser bold + letterSpacing alto — ficam regular/medium e mais
      discretos, para que só números e badges de decisão chamem atenção.
    - Textos de métrica (R$/KM, R$/H, R$/MIN) trocados por @string/metric_km,
      @string/metric_hour, @string/metric_min — já existiam em strings.xml e
      estavam hardcoded por engano.

  Cores já existentes usadas: @color/bg_card, @color/text_primary, @color/text_secondary,
  @color/text_tertiary, @color/text_inverse, @color/text_on_dark, @color/warning,
  @color/bg_surface, @color/card_header_dark, @color/success, @color/error.
-->

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@color/bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══════════════════════════════════════════════════════
             HEADER ESCURO — serviço · decisão · preço · lucro · bônus
             ═══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_ride_card_top_dark"
            android:paddingStart="@dimen/card_padding"
            android:paddingEnd="@dimen/card_padding"
            android:paddingTop="@dimen/card_padding"
            android:paddingBottom="@dimen/card_padding">

            <!-- Linha 1: badge serviço + badge decisão -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <!-- Badge de serviço -->
                <LinearLayout
                    android:id="@+id/layoutServiceBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_service_badge_dark"
                    android:paddingStart="8dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp">

                    <ImageView
                        android:id="@+id/tvServiceTypeIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_car"
                        android:tint="@color/text_on_dark" />

                    <TextView
                        android:id="@+id/tvServiceType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_12"
                        android:textStyle="bold"
                        android:textColor="@color/text_on_dark"
                        android:letterSpacing="0.02"
                        android:layout_marginStart="6dp" />

                </LinearLayout>

                <!-- Badge de decisão (ACEITAR / RECUSAR) -->
                <TextView
                    android:id="@+id/tvDecisionBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:textSize="@dimen/text_size_11"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:visibility="gone"
                    android:layout_marginStart="8dp" />
                <!--
                  No adapter, defina o background dinamicamente:
                    view.tvDecisionBadge.setBackgroundResource(
                        if (aceitar) R.drawable.bg_decision_accept
                        else R.drawable.bg_decision_decline
                    )
                  A cor do texto já é tratada pelo adapter via textColor.
                -->

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/ivCardMenu"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_more_vert"
                    android:tint="@color/text_on_dark"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />

            </LinearLayout>

            <!-- Linha 2: preço principal + lucro estimado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <!-- Preço -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <TextView
                        android:id="@+id/tvPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_32"
                        android:textStyle="bold"
                        android:textColor="@color/text_on_dark"
                        android:lineSpacingExtra="0dp" />

                </LinearLayout>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Lucro estimado -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end"
                    android:layout_marginBottom="4dp">

                    <!-- Label "Lucro est." -->
                    <TextView
                        android:id="@+id/tvProfitLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_9"
                        android:textStyle="bold"
                        android:textColor="@color/text_on_dark"
                        android:alpha="0.8"
                        android:letterSpacing="0.04"
                        android:visibility="gone" />

                    <!-- Valor do lucro -->
                    <TextView
                        android:id="@+id/tvProfitValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        android:visibility="gone" />

                </LinearLayout>

                    <TextView
                        android:id="@+id/tvProfitIcon"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

            </LinearLayout>

            <!-- Linha 3: bônus de prioridade · bônus dinâmico · rating -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tvPriorityBonus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_10"
                    android:textStyle="bold"
                    android:textColor="@color/warning"
                    android:background="@drawable/bg_bonus_pill_dark"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvDynamicBonus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_10"
                    android:textStyle="bold"
                    android:textColor="@color/warning"
                    android:background="@drawable/bg_bonus_pill_dark"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:gravity="center"
                    android:visibility="gone" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Rating -->
                <LinearLayout
                    android:id="@+id/layoutRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_score_pill"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:id="@+id/tvRatingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_11"
                        android:textStyle="bold"
                        android:textColor="@color/text_on_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textSize="@dimen/text_size_11"
                        android:textColor="@color/overlay_warning" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
        <!-- fim header escuro -->

        <!-- ═══════════════════════════════════════════════════════
             CORPO — métricas · rota · total
             ═══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/card_padding"
            android:paddingTop="@dimen/card_padding"
            android:paddingBottom="@dimen/card_padding">

            <!-- Métricas: R$/km · R$/h · R$/min -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- R$/KM -->
                <LinearLayout
                    android:id="@+id/layoutKmMetric"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_metric_cell"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/metric_km"
                        android:textSize="@dimen/text_size_9"
                        android:textStyle="normal"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.04" />

                    <TextView
                        android:id="@+id/tvPricePerKm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_16"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="3dp" />

                    <TextView
                        android:id="@+id/tvKmBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_9"
                        android:textStyle="bold"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- R$/H -->
                <LinearLayout
                    android:id="@+id/layoutHourMetric"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_metric_cell"
                    android:layout_marginHorizontal="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/metric_hour"
                        android:textSize="@dimen/text_size_9"
                        android:textStyle="normal"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.04" />

                    <TextView
                        android:id="@+id/tvPricePerHour"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_16"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="3dp" />

                    <TextView
                        android:id="@+id/tvHourBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_9"
                        android:textStyle="bold"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- R$/MIN -->
                <LinearLayout
                    android:id="@+id/layoutMinMetric"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_metric_cell"
                    android:layout_marginStart="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/metric_min"
                        android:textSize="@dimen/text_size_9"
                        android:textStyle="normal"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.04" />

                    <TextView
                        android:id="@+id/tvPricePerMin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_16"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="3dp" />

                    <TextView
                        android:id="@+id/tvMinBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_9"
                        android:textStyle="bold"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>
            <!-- fim métricas -->

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@color/bg_surface" />

            <!-- ─── ROTA com linha conectora ─── -->
            <LinearLayout
                android:id="@+id/layoutTripInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- EMBARQUE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top">

                    <!-- Coluna do indicador visual (ponto verde + linha) -->
                    <LinearLayout
                        android:layout_width="20dp"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_marginTop="3dp"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:id="@+id/ivPickupIcon"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:src="@drawable/ic_pickup"
                            android:tint="@color/success"
                            android:contentDescription="Embarque" />

                        <!-- Linha conectora entre os dois pontos -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginTop="3dp"
                            android:minHeight="20dp"
                            android:background="@drawable/bg_route_line_gradient" />

                    </LinearLayout>

                    <!-- Dados do embarque -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EMBARQUE"
                            android:textSize="@dimen/text_size_9"
                            android:textStyle="normal"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.04"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tvPickupAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/text_primary"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:id="@+id/tvPickupDistance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_11"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" · "
                                android:textSize="@dimen/text_size_11"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvPickupTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_11"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
                <!-- fim embarque -->

                <!-- DESTINO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top">

                    <!-- Ponto vermelho (sem linha abaixo) -->
                    <LinearLayout
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_marginTop="3dp"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:id="@+id/ivDropoffIcon"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:src="@drawable/ic_dropoff"
                            android:tint="@color/error"
                            android:contentDescription="Destino" />

                    </LinearLayout>

                    <!-- Dados do destino -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DESTINO"
                            android:textSize="@dimen/text_size_9"
                            android:textStyle="normal"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.04"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tvDropoffAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/text_primary"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:id="@+id/tvDropoffDistance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_11"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" · "
                                android:textSize="@dimen/text_size_11"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvDropoffTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_11"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
                <!-- fim destino -->

            </LinearLayout>
            <!-- fim bloco de rota -->

            <!-- Paradas intermediárias -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/ivStops"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_multiple_stops"
                    android:tint="@color/warning"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvStops"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_11"
                    android:textStyle="bold"
                    android:textColor="@color/warning"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:background="@color/bg_surface" />

            <!-- ─── Linha de total (km · tempo · score) ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textSize="@dimen/text_size_12"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvTotalInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textSize="@dimen/text_size_12"
                    android:textStyle="bold"
                    android:background="@drawable/bg_score_pill" />

            </LinearLayout>

            <!-- ─── Painel expandível de detalhes de lucro ─── -->
            <LinearLayout
                android:id="@+id/expandableProfitDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_expandable_rounded"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvProfitDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_12"
                    android:textColor="@color/text_secondary"
                    android:gravity="center" />

            </LinearLayout>

            <!-- ─── Rodapé: status · detalhar · timestamp ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_13" />

                <TextView
                    android:id="@+id/btnExpandProfit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ detalhar corrida"
                    android:textSize="@dimen/text_size_11"
                    android:textColor="@color/text_secondary"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="4dp"
                    android:paddingHorizontal="4dp"
                    android:layout_marginStart="10dp"
                    android:background="?attr/selectableItemBackground" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_11"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

        </LinearLayout>
        <!-- fim corpo -->

    </LinearLayout>

</androidx.cardview.widget.CardView>
