<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:backgroundTint="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Row 1: icon + name + status + actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvExpenseIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:textSize="14sp"
                android:text="\uD83D\uDCB0" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tvExpenseName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A2C3E" />

                <TextView
                    android:id="@+id/tvExpenseStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvExpenseValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A2C3E"
                android:layout_marginEnd="4dp" />

        </LinearLayout>

        <!-- Row 2: detail / installment progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="4dp">

            <TextView
                android:id="@+id/tvExpenseDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#6B7280"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

        <!-- Row 3: action buttons -->
        <LinearLayout
            android:id="@+id/expenseActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="6dp"
            android:paddingTop="6dp"
            android:divider="?android:attr/dividerVertical"
            android:showDividers="middle">

            <TextView
                android:id="@+id/btnPayPartial"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="\uD83D\uDCB0 Pagar"
                android:textSize="10sp"
                android:textColor="#1A2C3E"
                android:background="@drawable/pill_unselected"
                android:paddingHorizontal="10dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnQuit"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="\u2705 Quitar"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/pill_selected"
                android:paddingHorizontal="10dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnEditExpense"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="\u270F\uFE0F"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnDeleteExpense"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="\uD83D\uDDD1"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
