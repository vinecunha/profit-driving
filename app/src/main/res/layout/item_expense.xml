<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:backgroundTint="@color/bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="10dp"
        android:paddingHorizontal="8dp">

        <!-- Row 1: icon + name + status + actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvExpenseIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:textSize="@dimen/text_size_14"
                android:text="\uD83D\uDCB0" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tvExpenseName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_14"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvExpenseStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_10"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvExpenseValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_13"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="4dp" />

        </LinearLayout>

        <!-- Row 2: detail / installment progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="4dp">

            <TextView
                android:id="@+id/tvExpenseDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_10"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

        <!-- Row 3: action buttons -->
        <LinearLayout
            android:id="@+id/expenseActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="6dp"
            android:paddingTop="6dp">

            <TextView
                android:id="@+id/btnPayPartial"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="💰 Pagar Parcialmente"
                android:textSize="@dimen/text_size_10"
                android:textColor="@color/text_primary"
                android:background="@drawable/pill_unselected"
                android:paddingHorizontal="10dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnQuit"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="✅ Quitar"
                android:textSize="@dimen/text_size_10"
                android:textColor="@color/text_inverse"
                android:background="@drawable/pill_selected"
                android:paddingHorizontal="10dp"
                android:layout_marginEnd="8dp"          
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnEditExpense"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="✏️ Editar"
                android:textSize="@dimen/text_size_12"
                android:paddingHorizontal="10dp"
                android:layout_marginEnd="4dp"          
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnDeleteExpense"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="🗑️"
                android:textSize="@dimen/text_size_12"
                android:paddingHorizontal="10dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

                
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
