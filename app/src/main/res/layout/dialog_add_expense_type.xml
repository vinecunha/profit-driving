<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\u2795 ADICIONAR DESPESA"
        android:textSize="@dimen/text_size_18"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Qual o tipo de despesa?"
        android:textSize="@dimen/text_size_13"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/btnTypePerKm"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="\uD83D\uDCB0 POR KM\ncombust\u00EDvel, manuten\u00E7\u00E3o, pneus"
        android:textSize="@dimen/text_size_12"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:background="@drawable/pill_unselected"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="6dp"
        android:lineSpacingExtra="2dp" />

    <TextView
        android:id="@+id/btnTypeFixed"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:text="\uD83D\uDCC5 FIXO\nseguro, IPVA, financiamento"
        android:textSize="@dimen/text_size_12"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:background="@drawable/pill_unselected"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="6dp"
        android:lineSpacingExtra="2dp" />

    <TextView
        android:id="@+id/btnTypeEvent"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:text="\uD83C\uDFAF EVENTO\nestacionamento, ped\u00E1gio"
        android:textSize="@dimen/text_size_12"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:background="@drawable/pill_unselected"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="6dp"
        android:lineSpacingExtra="2dp" />

</LinearLayout>
