<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <include layout="@layout/toolbar_default" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#F8F9FE">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btnModeDay"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="\uD83D\uDCC5 Dia"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/pill_selected"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnModeWeek"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="\uD83D\uDCC6 Semana"
                android:textSize="14sp"
                android:background="@drawable/pill_unselected"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnModeMonth"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="\uD83D\uDCCA M\u00EAs"
                android:textSize="14sp"
                android:background="@drawable/pill_unselected"
                android:layout_marginStart="4dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/btnPrevPeriod"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="\u25C0"
                android:textSize="18sp"
                android:textColor="#1A2C3E"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvPeriodTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Carregando..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A2C3E"
                android:gravity="center" />

            <TextView
                android:id="@+id/btnNextPeriod"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="\u25B6"
                android:textSize="18sp"
                android:textColor="#1A2C3E"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnToday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\uD83D\uDCCD Hoje"
            android:textSize="12sp"
            android:textColor="#00982B"
            android:padding="8dp"
            android:layout_gravity="center"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/skeletonContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/cardsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <include layout="@layout/bottom_nav" />

</LinearLayout>
