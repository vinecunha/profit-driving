<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <include layout="@layout/toolbar_default" />

    <!-- Card de navegação de período (mesmo layout do Meu Dia) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:elevation="2dp"
        android:padding="16dp"
        android:layout_margin="12dp"
        android:layout_marginBottom="0dp">

        <!-- Botões de modo Dia/Semana/Mês -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/btnModeDay"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="\uD83D\uDCC5 Dia"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/pill_selected"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnModeWeek"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="\uD83D\uDCC6 Semana"
                android:textSize="13sp"
                android:background="@drawable/pill_unselected"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnModeMonth"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="\uD83D\uDCCA M\u00EAs"
                android:textSize="13sp"
                android:background="@drawable/pill_unselected"
                android:layout_marginStart="4dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Navegação por período -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/btnPrevPeriod"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="\u25C0"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvPeriodTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Carregando..."
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <TextView
                android:id="@+id/btnNextPeriod"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="\u25B6"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Botão Hoje -->
        <TextView
            android:id="@+id/btnToday"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Hoje"
            android:textSize="12sp"
            android:textColor="@color/success"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/pill_unselected"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/skeletonContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/cardsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </ScrollView>

    <include layout="@layout/bottom_nav" />

</LinearLayout>
