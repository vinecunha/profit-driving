<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp"
    android:minWidth="280dp"
    android:clickable="true"
    android:focusable="true">

    <!-- ============================================ -->
    <!-- LINHA 1: 2 COLUNAS                           -->
    <!-- Coluna 1: Valor (cima) + Serviço (baixo)    -->
    <!-- Coluna 2: Lucro (cima) + Bônus (baixo)      -->
    <!-- ============================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <!-- COLUNA 1: Valor + Serviço -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvServiceType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/highlight"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- COLUNA 2: Lucro + Bônus -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Lucro (em cima) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvProfitLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📈"
                    android:textColor="@color/overlay_success"
                    android:textSize="11sp"
                    android:ellipsize="start"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProfit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/overlay_success"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="2dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Bônus (embaixo) - Prioridade e Dinâmica lado a lado -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tvPriorityBonus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/highlight"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvDynamicBonus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/highlight"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ============================================ -->
    <!-- LINHA 2: Métricas (título em cima, valor embaixo) -->
    <!-- ============================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <!-- R$/km -->
        <LinearLayout
            android:id="@+id/kmRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$/km"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tvKm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- R$/h -->
        <LinearLayout
            android:id="@+id/hourRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$/h"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tvHour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- R$/min -->
        <LinearLayout
            android:id="@+id/minuteRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$/min"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tvMinute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Nota -->
        <LinearLayout
            android:id="@+id/ratingRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ============================================ -->
    <!-- LINHA 3: Distância + Tempo + Destino + Paradas -->
    <!-- ============================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            android:layout_marginEnd="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛣️"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp"
                android:layout_marginStart="2dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginEnd="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp"
                android:layout_marginStart="3dp" />

        </LinearLayout>

        <ImageView
            android:id="@+id/ivKnownDestination"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_favorite"
            android:tint="@color/highlight"
            android:visibility="gone" />
        <TextView
            android:id="@+id/tvKnownDestination"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="9sp"
            android:textColor="@color/highlight"
            android:gravity="start"
            android:maxLines="1"
            android:ellipsize="start"
            android:layout_marginStart="3dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutStops"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivStops"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/ic_multiple_stops"
                android:tint="@color/highlight" />

            <TextView
                android:id="@+id/tvStops"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Paradas"
                android:textSize="8sp"
                android:textColor="@color/highlight"
                android:layout_marginStart="3dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ============================================ -->
    <!-- tvApp oculto (compatibilidade)               -->
    <!-- ============================================ -->
    <TextView
        android:id="@+id/tvApp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- ============================================ -->
    <!-- DECISÃO (oculta mas presente para o código)  -->
    <!-- ============================================ -->
    <TextView
        android:id="@+id/tvDecision"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- ============================================ -->
    <!-- Views ocultas (compatibilidade)              -->
    <!-- ============================================ -->
    <TextView
        android:id="@+id/tvScore"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvBonus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <View
        android:id="@+id/dotKm"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <View
        android:id="@+id/dotHour"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <View
        android:id="@+id/dotMinute"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <View
        android:id="@+id/dotRating"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>