<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp"
    android:minWidth="220dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Linha 1: App + Valor + Tipo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp">

        <TextView
            android:id="@+id/tvApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/overlay_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="end"/>

        <TextView
            android:id="@+id/tvServiceType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_warning"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Linha 2: 4 colunas (R$/km, R$/h, R$/min, Nota) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="1dp"
        android:gravity="center">

        <!-- Coluna R$/km -->
        <LinearLayout
            android:id="@+id/kmRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$/km"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvKm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/dotKm"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Coluna R$/h -->
        <LinearLayout
            android:id="@+id/hourRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$/h"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvHour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/dotHour"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Coluna R$/min -->
        <LinearLayout
            android:id="@+id/minuteRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$/min"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvMinute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/dotMinute"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Coluna Nota -->
        <LinearLayout
            android:id="@+id/ratingRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/dotRating"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- Linha 3: Distância e Tempo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="1dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvDistance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="10sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="10sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Linha 4: Bônus (se houver) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvBonus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_warning"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tvPriorityBonus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_warning"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDynamicBonus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_warning"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- Linha 5: Decisão (BOA/REVISAR/RUIM) -->
    <TextView
        android:id="@+id/tvDecision"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:gravity="center"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/overlay_text_primary"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

    <!-- Linha 6: Pontuação (opcional) -->
    <TextView
        android:id="@+id/tvScore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="9sp"
        android:textColor="@color/overlay_text_secondary"
        android:gravity="center"
        android:layout_marginTop="2dp"
        android:visibility="gone" />

    <!-- Linha 7: Lucro -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="2dp">

        <TextView
            android:id="@+id/tvProfitLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/overlay_text_secondary"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvProfit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/overlay_success"
            android:singleLine="true"
            android:ellipsize="end"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Linha 8: Stops -->
    <LinearLayout
        android:id="@+id/layoutStops"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginStart="8dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivStops"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_multiple_stops"
            android:tint="@color/overlay_warning" />

        <TextView
            android:id="@+id/tvStops"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" Várias paradas"
            android:textSize="9sp"
            android:textColor="@color/overlay_warning"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- Linha 9: Destino conhecido -->
    <TextView
        android:id="@+id/tvKnownDestination"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\uD83D\uDCCD Destino conhecido · 0x"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/overlay_warning"
        android:layout_marginTop="2dp"
        android:layout_gravity="center"
        android:visibility="gone" />

</LinearLayout>
