<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⛽ Novo Abastecimento"
            android:textSize="@dimen/text_size_18"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <!-- Fuel Type - Row 1: Liquid fuels -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de energia"
            android:textSize="@dimen/text_size_12"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/btnFuelGasoline"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginEnd="2dp"
                android:text="⛽ Gasolina"
                android:textSize="@dimen/text_size_10"
                android:textColor="@color/text_inverse"
                android:gravity="center"
                android:background="@drawable/pill_selected"
                android:clickable="true"
                android:focusable="true"
                android:lines="1" />

            <TextView
                android:id="@+id/btnFuelEthanol"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:text="🌽 Etanol"
                android:textSize="@dimen/text_size_10"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="@drawable/pill_unselected"
                android:clickable="true"
                android:focusable="true"
                android:lines="1" />

            <TextView
                android:id="@+id/btnFuelDiesel"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:text="🛢️ Diesel"
                android:textSize="@dimen/text_size_10"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="@drawable/pill_unselected"
                android:clickable="true"
                android:focusable="true"
                android:lines="1" />

            <TextView
                android:id="@+id/btnFuelGNV"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="2dp"
                android:text="🔥 GNV"
                android:textSize="@dimen/text_size_10"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="@drawable/pill_unselected"
                android:clickable="true"
                android:focusable="true"
                android:lines="1" />

        </LinearLayout>

        <!-- Fuel Type - Row 2: Electric and hybrid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/btnFuelElectricAC"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginEnd="2dp"
                android:text="🔌 Elétrico AC"
                android:textSize="@dimen/text_size_10"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="@drawable/pill_unselected"
                android:clickable="true"
                android:focusable="true"
                android:lines="1" />

            <TextView
                android:id="@+id/btnFuelElectricDC"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:text="⚡ Elétrico DC"
                android:textSize="@dimen/text_size_10"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="@drawable/pill_unselected"
                android:clickable="true"
                android:focusable="true"
                android:lines="1" />

            <TextView
                android:id="@+id/btnFuelHybrid"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="2dp"
                android:text="🔋 Híbrido"
                android:textSize="@dimen/text_size_10"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="@drawable/pill_unselected"
                android:clickable="true"
                android:focusable="true"
                android:lines="1" />

        </LinearLayout>

        <EditText
            android:id="@+id/etOdometer"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:inputType="numberDecimal"
            android:hint="Hodômetro (km)"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/text_primary"
            android:background="@drawable/pill_unselected"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etTotalValue"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:inputType="numberDecimal"
            android:hint="Valor total (R$)"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/text_primary"
            android:background="@drawable/pill_unselected"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etPricePerUnit"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:inputType="numberDecimal"
            android:hint="Preço por unidade (R$)"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/text_primary"
            android:background="@drawable/pill_unselected"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etAmount"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:inputType="numberDecimal"
            android:hint="Quantidade (L) - calculado automaticamente"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/text_tertiary"
            android:background="@drawable/pill_unselected"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Electric-specific: Charger type -->
        <LinearLayout
            android:id="@+id/chargerGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo de carregador"
                android:textSize="@dimen/text_size_12"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/btnChargerAC"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp"
                    android:text="🔌 AC"
                    android:textSize="@dimen/text_size_11"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnChargerDC"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:text="⚡ DC rápido"
                    android:textSize="@dimen/text_size_11"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnChargerHome"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:text="🏠 Casa"
                    android:textSize="@dimen/text_size_11"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

        <!-- Electric-specific: Battery percentage -->
        <LinearLayout
            android:id="@+id/percentageGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etPercentageStart"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:inputType="number"
                android:hint="% inicial"
                android:textSize="@dimen/text_size_14"
                android:textColor="@color/text_primary"
                android:background="@drawable/pill_unselected"
                android:paddingHorizontal="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textSize="@dimen/text_size_16"
                android:textColor="@color/text_tertiary"
                android:layout_marginHorizontal="4dp" />

            <EditText
                android:id="@+id/etPercentageEnd"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:inputType="number"
                android:hint="% final"
                android:textSize="@dimen/text_size_14"
                android:textColor="@color/text_primary"
                android:background="@drawable/pill_unselected"
                android:paddingHorizontal="12dp" />

        </LinearLayout>

        <!-- Full tank toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Completo?"
                android:textSize="@dimen/text_size_14"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/btnFullTankYes"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:paddingHorizontal="14dp"
                android:text="✅ SIM"
                android:textSize="@dimen/text_size_12"
                android:textColor="@color/text_inverse"
                android:gravity="center"
                android:background="@drawable/pill_selected"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btnFullTankNo"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:paddingHorizontal="14dp"
                android:text="❌ NÃO"
                android:textSize="@dimen/text_size_12"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:background="@drawable/pill_unselected"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnConfirmRefuel"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="➕ REGISTRAR ABASTECIMENTO"
            android:textSize="@dimen/text_size_13"
            android:textStyle="bold"
            android:textColor="@color/text_inverse"
            android:background="@drawable/pill_selected"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</ScrollView>
