<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp"
            android:background="#2E7D32">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_launcher"
                android:contentDescription=""
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Parâmetros"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voltar"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingVertical="4dp"
                android:paddingHorizontal="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

        </LinearLayout>

        <!-- Parâmetros de Avaliação Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/inner_card_bg"
            android:padding="16dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Parâmetros de Avaliação"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="16dp" />

            <!-- R$/km -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ / km"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mínimo (vermelho)"
                    android:textSize="11sp"
                    android:textColor="#F87171"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ideal (verde)"
                    android:textSize="11sp"
                    android:textColor="#4ADE80"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etMinKm"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:hint="Ex: 2,50"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:background="@drawable/pill_unselected"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="4dp" />

                <EditText
                    android:id="@+id/etIdealKm"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:hint="Ex: 4,00"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:background="@drawable/pill_unselected"
                    android:paddingHorizontal="12dp"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- R$/h -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ / hora"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mínimo (vermelho)"
                    android:textSize="11sp"
                    android:textColor="#F87171"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ideal (verde)"
                    android:textSize="11sp"
                    android:textColor="#4ADE80"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etMinHour"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:hint="Ex: 30,00"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:background="@drawable/pill_unselected"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="4dp" />

                <EditText
                    android:id="@+id/etIdealHour"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:hint="Ex: 60,00"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:background="@drawable/pill_unselected"
                    android:paddingHorizontal="12dp"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- R$/min -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ / minuto"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mínimo (vermelho)"
                    android:textSize="11sp"
                    android:textColor="#F87171"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ideal (verde)"
                    android:textSize="11sp"
                    android:textColor="#4ADE80"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etMinMinute"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:hint="Ex: 0,50"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:background="@drawable/pill_unselected"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="4dp" />

                <EditText
                    android:id="@+id/etIdealMinute"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:hint="Ex: 1,00"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:background="@drawable/pill_unselected"
                    android:paddingHorizontal="12dp"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- Nota -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nota do passageiro"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mínimo (vermelho)"
                    android:textSize="11sp"
                    android:textColor="#F87171"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ideal (verde)"
                    android:textSize="11sp"
                    android:textColor="#4ADE80"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etMinRating"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:hint="Ex: 4,50"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:background="@drawable/pill_unselected"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="4dp" />

                <EditText
                    android:id="@+id/etIdealRating"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:hint="Ex: 4,90"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:background="@drawable/pill_unselected"
                    android:paddingHorizontal="12dp"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Aparência do Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/inner_card_bg"
            android:padding="16dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aparência do Card"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Layout do card"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/btnColuna"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Coluna"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/pill_selected"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnLinha"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Linha"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:gravity="center"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lado da tela"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/btnEsquerda"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Esquerda"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/pill_selected"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnDireita"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Direita"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:gravity="center"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Métricas visíveis"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/btnShowKm"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp"
                    android:text="R$/km"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/pill_selected"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnShowHour"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:text="R$/h"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/pill_selected"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnShowMinute"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:text="R$/min"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/pill_selected"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnShowRating"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:text="Nota"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/pill_selected"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvYLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Altura na tela: 30%"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="8dp" />

            <SeekBar
                android:id="@+id/seekY"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="90"
                android:progress="30"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0% = topo | 90% = parte inferior"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

        <!-- Importância dos parâmetros -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/inner_card_bg"
            android:padding="16dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Importância dos parâmetros"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp" />

            <!-- R$/km weight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="R$/km"
                    android:textSize="14sp"
                    android:textColor="#333333" />

                <SeekBar
                    android:id="@+id/seekWeightKm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="4"
                    android:progress="4" />

                <TextView
                    android:id="@+id/tvWeightKmStars"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="★★★★★"
                    android:textSize="14sp"
                    android:textColor="#FFD700"
                    android:gravity="end" />

            </LinearLayout>

            <!-- R$/h weight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="R$/h"
                    android:textSize="14sp"
                    android:textColor="#333333" />

                <SeekBar
                    android:id="@+id/seekWeightHour"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="4"
                    android:progress="3" />

                <TextView
                    android:id="@+id/tvWeightHourStars"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="★★★★"
                    android:textSize="14sp"
                    android:textColor="#FFD700"
                    android:gravity="end" />

            </LinearLayout>

            <!-- R$/min weight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="R$/min"
                    android:textSize="14sp"
                    android:textColor="#333333" />

                <SeekBar
                    android:id="@+id/seekWeightMin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="4"
                    android:progress="2" />

                <TextView
                    android:id="@+id/tvWeightMinStars"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="★★★"
                    android:textSize="14sp"
                    android:textColor="#FFD700"
                    android:gravity="end" />

            </LinearLayout>

            <!-- Nota weight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Nota"
                    android:textSize="14sp"
                    android:textColor="#333333" />

                <SeekBar
                    android:id="@+id/seekWeightRating"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="4"
                    android:progress="1" />

                <TextView
                    android:id="@+id/tvWeightRatingStars"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="★★"
                    android:textSize="14sp"
                    android:textColor="#FFD700"
                    android:gravity="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Thresholds de decisão -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/inner_card_bg"
            android:padding="16dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thresholds de decisão"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Define a pontuação mínima para cada tag. Pontuação = soma dos pesos × estado de cada parâmetro."
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginBottom="16dp" />

            <!-- ACEITAR threshold -->
            <TextView
                android:id="@+id/tvThresholdAceitarLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACEITAR se pontuação ≥ 80%"
                android:textSize="13sp"
                android:textColor="#00A86B"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <SeekBar
                android:id="@+id/seekThresholdAceitar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="50"
                android:progress="30"
                android:layout_marginBottom="16dp" />

            <!-- ANALISAR threshold -->
            <TextView
                android:id="@+id/tvThresholdAnalisarLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANALISAR se pontuação ≥ 50%"
                android:textSize="13sp"
                android:textColor="#F97316"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <SeekBar
                android:id="@+id/seekThresholdAnalisar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="59"
                android:progress="30"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Abaixo disso = RECUSAR"
                android:textSize="11sp"
                android:textColor="#9CA3AF" />

        </LinearLayout>

        <!-- Preview Card -->
        <LinearLayout
            android:id="@+id/previewCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/inner_card_bg"
            android:padding="12dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Simulação com valores de exemplo"
                android:textSize="12sp"
                android:textColor="#888888" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/pvKm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/pvHour"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/pvMin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/pvRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/pvDecision"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:id="@+id/pvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Demo Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/inner_card_bg"
            android:padding="16dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/btnDemo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Visualizar card de exemplo"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:gravity="center"
                android:padding="12dp"
                android:background="@drawable/pill_unselected"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Save Button -->
        <TextView
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            android:text="Salvar"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/pill_selected"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</ScrollView>
