<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <include layout="@layout/toolbar_default" />

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Card: Combustível / GNV -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_costs"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\u26FD Abastecimentos"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <!-- Action row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/btnAddRefuel"
                    style="@style/PillSelected"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="+ Adicionar" />

                <TextView
                    android:id="@+id/btnViewAllRefuels"
                    style="@style/PillUnselected"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="\uD83D\uDC41\uFE0F Ver todos" />

            </LinearLayout>

            <!-- Refuel History -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83D\uDCCA \u00daltimos abastecimentos"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Table header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="4dp"
                android:paddingHorizontal="8dp"
                android:background="@color/bg_surface">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Data"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hod\u00f4metro"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.7"
                    android:text="Litros"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pre\u00e7o"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="km/L"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:gravity="end" />

                <View
                    android:layout_width="64dp"
                    android:layout_height="0dp"
                    android:visibility="invisible" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bg_surface" />

            <LinearLayout
                android:id="@+id/refuelList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhum abastecimento registrado"
                    android:textSize="12sp"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center"
                    android:paddingVertical="12dp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bg_surface"
                android:layout_marginBottom="8dp" />

            <!-- Stats by fuel type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83D\uDCCA M\u00e9dias por tipo de energia"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/energyStatsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp" />

        </LinearLayout>

        <!-- Card: Custos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_costs"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83D\uDCB0 Despesas"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Km mensal:"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/etMonthlyKm"
                    android:layout_width="100dp"
                    android:layout_height="36dp"
                    android:inputType="number"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/pill_unselected"
                    android:paddingHorizontal="10dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

            <!-- Custos Variáveis (por km) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83D\uDEE4\uFE0F Vari\u00e1veis (por km)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/perKmList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhum custo vari\u00e1vel"
                    android:textSize="12sp"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center"
                    android:paddingVertical="6dp" />

            </LinearLayout>

<!-- Action row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/btnAddPerKm"
                    style="@style/PillSelected"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:text="+ Vari\u00e1vel" />

                <TextView
                    android:id="@+id/btnAddFixed"
                    style="@style/PillSelected"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    android:text="+ Fixo" />

                <TextView
                    android:id="@+id/btnAddEvent"
                    style="@style/PillSelected"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    android:text="+ Evento" />

                <TextView
                    android:id="@+id/btnViewExpenses"
                    style="@style/PillUnselected"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:text="\uD83D\uDC41\uFE0F Ver todos" />

            </LinearLayout>

        </LinearLayout>

        <!-- Card: Resumo de Custos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_costs"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83D\uDCB0 RESUMO DE CUSTOS"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@color/bg_surface">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\uD83D\uDCCB Despesas por km (detalhado)"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:id="@+id/normalizedExpenseList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border"
                    android:layout_marginVertical="6dp" />

        <TextView
            android:id="@+id/tvFuelCostKm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Combust\u00edvel/km: --"
            android:textSize="15sp"
                    android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvFixedCostKm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total fixos/km: --"
            android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvVariableCostKm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Var\u00e1veis/km: --"
            android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border"
                    android:layout_marginVertical="6dp" />

        <TextView
            android:id="@+id/tvTotalCostKm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CUSTO TOTAL/km: --"
            android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tvCostPerHour"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Custo/hora: --"
            android:textSize="15sp"
                    android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvCostPerMinute"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Custo/min: --"
            android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Card: Simulador de Lucro -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_costs"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83C\uDFAF SIMULADOR DE LUCRO"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <!-- Visual range indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@color/bg_surface"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ruim"
                        android:textSize="11sp"
                        android:textColor="@color/error"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Aceit\u00e1vel"
                        android:textSize="11sp"
                        android:textColor="@color/warning"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Bom"
                        android:textSize="11sp"
                        android:textColor="@color/success"
                        android:textStyle="bold"
                        android:gravity="end" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:background="@drawable/progress_bar_gradient"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

        <TextView
            android:id="@+id/tvRangeRuim"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="R$ --"
            android:textSize="11sp"
            android:textColor="@color/error" />

                <TextView
                    android:id="@+id/tvRangeAceitavel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="R$ --"
                    android:textSize="11sp"
                    android:textColor="@color/warning"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvRangeBom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="R$ --"
                    android:textSize="11sp"
                    android:textColor="@color/success"
                    android:gravity="end" />

                </LinearLayout>

            </LinearLayout>

        <TextView
            android:id="@+id/tvYourCost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seu custo/km: --"
            android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvProfit30"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Para lucro de 30%: precisa R$ --/km"
            android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvProfit50"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Para lucro de 50%: precisa R$ --/km"
            android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvProfit100"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Para lucro de 100%: precisa R$ --/km"
            android:textSize="15sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Card: Estatisticas Mensais -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_costs"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83D\uDCCA Estat\u00edsticas"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Acompanhe seu desempenho por m\u00eas: KM rodados, custo de combust\u00edvel e consumo m\u00e9dio."
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/btnViewStats"
                style="@style/PillUnselected"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:text="\uD83D\uDC41\uFE0F Ver mensal" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>

<include layout="@layout/bottom_nav" />

</LinearLayout>
