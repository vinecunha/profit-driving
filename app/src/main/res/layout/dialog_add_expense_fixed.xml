<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvFixedTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\uD83D\uDCC5 DESPESA FIXA"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecione ou digite o nome:"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/fixedSuggestionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/btnFixedSeguro"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:gravity="center_vertical"
                android:text="\uD83D\uDEE1\uFE0F Seguro"
                android:textSize="12sp"
                android:textColor="#1A1A2E"
                android:background="@drawable/pill_unselected"
                android:paddingHorizontal="12dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/btnFixedIpva"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:gravity="center_vertical"
                android:text="\uD83D\uDCB0 IPVA"
                android:textSize="12sp"
                android:textColor="#1A1A2E"
                android:background="@drawable/pill_unselected"
                android:paddingHorizontal="12dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/btnFixedFinanciamento"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:gravity="center_vertical"
                android:text="\uD83C\uDFE6 Financiamento"
                android:textSize="12sp"
                android:textColor="#1A1A2E"
                android:background="@drawable/pill_unselected"
                android:paddingHorizontal="12dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/btnFixedManutencao"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:gravity="center_vertical"
                android:text="\uD83D\uDD27 Manuten\u00E7\u00E3o preventiva"
                android:textSize="12sp"
                android:textColor="#1A1A2E"
                android:background="@drawable/pill_unselected"
                android:paddingHorizontal="12dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/btnFixedOutro"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:gravity="center_vertical"
                android:text="\u270F\uFE0F Outro..."
                android:textSize="12sp"
                android:textColor="#1A1A2E"
                android:background="@drawable/pill_unselected"
                android:paddingHorizontal="12dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <EditText
            android:id="@+id/etFixedName"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:inputType="text"
            android:hint="Nome personalizado"
            android:textSize="13sp"
            android:textColor="#1A1A2E"
            android:background="@drawable/pill_unselected"
            android:paddingHorizontal="12dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etFixedValue"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:inputType="numberDecimal"
            android:hint="Valor mensal (R$)"
            android:textSize="14sp"
            android:textColor="#1A1A2E"
            android:background="@drawable/pill_unselected"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Periodicidade"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/btnFixedMonthly"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginEnd="2dp"
                android:text="\uD83D\uDCC5 Mensal"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/pill_selected"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnFixedYearly"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="2dp"
                android:text="\uD83D\uDCC6 Anual (ex: IPVA)"
                android:textSize="11sp"
                android:textColor="#6B7280"
                android:gravity="center"
                android:background="@drawable/pill_unselected"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\uD83D\uDCA1 SUGEST\u00D5ES DE MERCADO:"
            android:textSize="10sp"
            android:textColor="#9CA3AF"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\u2022 Seguro: R$ 120 - R$ 350/m\u00EAs\n\u2022 IPVA: R$ 70 - R$ 250/m\u00EAs\n\u2022 Manuten\u00E7\u00E3o preventiva: R$ 70 - R$ 120/m\u00EAs"
            android:textSize="10sp"
            android:textColor="#9CA3AF"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btnCancelFixed"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                android:text="CANCELAR"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:background="@drawable/pill_unselected"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnSaveFixed"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:text="\u2705 SALVAR"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/pill_selected"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
