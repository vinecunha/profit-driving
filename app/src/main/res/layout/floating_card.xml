<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp"
    android:clickable="true"
    android:focusable="true"
    >

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvApp"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tvServiceType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_warning"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvBonus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/overlay_warning"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tvPriorityBonus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_warning"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvDynamicBonus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_warning"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/kmRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/tvKmLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R$/km"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvKm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <View
            android:id="@+id/dotKm"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/hourRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvHourLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R$/h"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvHour"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <View
            android:id="@+id/dotHour"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/minuteRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvMinuteLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R$/min"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvMinute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <View
            android:id="@+id/dotMinute"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/ratingRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvRatingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nota"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <View
            android:id="@+id/dotRating"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            android:layout_marginEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛣️"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp"
                android:layout_marginStart="3dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="10sp"
                android:layout_marginStart="3dp" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvDecision"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:gravity="center"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="@color/overlay_text_primary"
        android:layout_marginTop="6dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvScore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="6sp"
        android:textColor="@color/overlay_text_secondary"
        android:gravity="center"
        android:layout_marginTop="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/tvProfitLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/overlay_text_secondary"
            android:layout_marginEnd="4dp"
            android:singleLine="true"
            android:ellipsize="start"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvProfit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/overlay_success"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutStops"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivStops"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_multiple_stops"
            android:tint="@color/overlay_warning" />

        <TextView
            android:id="@+id/tvStops"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" Várias paradas"
            android:textSize="10sp"
            android:textColor="@color/overlay_warning"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvKnownDestination"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\uD83D\uDCCD Destino conhecido · 0x"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/overlay_warning"
        android:layout_marginTop="2dp"
        android:visibility="gone" />

</LinearLayout>
