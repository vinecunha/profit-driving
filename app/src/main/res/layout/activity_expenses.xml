<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <include layout="@layout/toolbar_default" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Summary Card -->
            <LinearLayout
                android:id="@+id/summaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_card"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\uD83D\uDCCA RESUMO"
                    android:textSize="@dimen/text_size_11"
                    android:textColor="@color/text_tertiary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvTotalCostPerKm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Custo total/km: --"
                    android:textSize="@dimen/text_size_24"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvFixedMonthlyCost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Custo fixo mensal: --"
                    android:textSize="@dimen/text_size_13"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_48"
                    android:text="\uD83D\uDCB0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma despesa cadastrada"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Adicione seus custos para\ncalcular o custo por km real"
                    android:textSize="@dimen/text_size_13"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- Expensive Content (visible when there are expenses) -->
            <LinearLayout
                android:id="@+id/expensesContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- CUSTOS POR KM -->
                <LinearLayout
                    android:id="@+id/perKmSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/bg_card"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="CUSTOS POR KM"
                            android:textSize="@dimen/text_size_11"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/btnAddPerKm"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:gravity="center"
                            android:text="\u2795"
                            android:textSize="@dimen/text_size_14"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/bg_surface" />

                    <LinearLayout
                        android:id="@+id/perKmList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

                <!-- CUSTOS FIXOS -->
                <LinearLayout
                    android:id="@+id/fixedSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/bg_card"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="CUSTOS FIXOS"
                            android:textSize="@dimen/text_size_11"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/btnAddFixed"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:gravity="center"
                            android:text="\u2795"
                            android:textSize="@dimen/text_size_14"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/bg_surface" />

                    <LinearLayout
                        android:id="@+id/fixedList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

                <!-- CUSTOS POR EVENTO -->
                <LinearLayout
                    android:id="@+id/eventSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/bg_card"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="CUSTOS POR EVENTO"
                            android:textSize="@dimen/text_size_11"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/btnAddEvent"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:gravity="center"
                            android:text="\u2795"
                            android:textSize="@dimen/text_size_14"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/bg_surface" />

                    <LinearLayout
                        android:id="@+id/eventList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </LinearLayout>

            <!-- Add Expense Button -->
            <TextView
                android:id="@+id/btnAddExpense"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:gravity="center"
                android:text="\u2795 ADICIONAR DESPESA"
                android:textSize="@dimen/text_size_13"
                android:textStyle="bold"
                android:textColor="@color/text_inverse"
                android:background="@drawable/pill_selected"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </ScrollView>

<include layout="@layout/bottom_nav" />

</LinearLayout>
