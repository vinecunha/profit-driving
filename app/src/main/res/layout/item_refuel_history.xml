<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp"
    android:paddingHorizontal="8dp">

    <TextView
        android:id="@+id/tvRefuelDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="@dimen/text_size_12"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/tvRefuelOdometer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="@dimen/text_size_12"
        android:textColor="@color/text_secondary"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvRefuelLiters"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.7"
        android:textSize="@dimen/text_size_12"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvRefuelPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="@dimen/text_size_12"
        android:textColor="@color/text_secondary"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvRefuelConsumption"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="@dimen/text_size_12"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="end" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnEditRefuel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✏️"
            android:textSize="@dimen/text_size_14"
            android:clickable="true" />

        <TextView
            android:id="@+id/btnDeleteRefuel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="🗑️"
            android:textSize="@dimen/text_size_14"
            android:clickable="true" />

    </LinearLayout>

</LinearLayout>
