<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FB">

    <include layout="@layout/toolbar_default" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Cabeçalho de Navegação entre Períodos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#F8F9FE"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/btnModeDay"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="\uD83D\uDCC5 Dia"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/pill_selected"
                        android:layout_marginEnd="4dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnModeWeek"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="\uD83D\uDCC6 Semana"
                        android:textSize="13sp"
                        android:background="@drawable/pill_unselected"
                        android:layout_marginHorizontal="4dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnModeMonth"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="\uD83D\uDCCA M\u00EAs"
                        android:textSize="13sp"
                        android:background="@drawable/pill_unselected"
                        android:layout_marginStart="4dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/btnPrevPeriod"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="\u25C0"
                        android:textSize="18sp"
                        android:textColor="#1A2C3E"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tvPeriodTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Carregando..."
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A2C3E"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/btnNextPeriod"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="\u25B6"
                        android:textSize="18sp"
                        android:textColor="#1A2C3E"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <TextView
                    android:id="@+id/btnToday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\uD83D\uDCCD Hoje"
                    android:textSize="11sp"
                    android:textColor="#00982B"
                    android:padding="8dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Resumo do Dia expandido -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg_costs"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\uD83D\uDCCA RESUMO DO DIA"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A2C3E"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tvRideCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Corridas: 0"
                        android:textSize="12sp"
                        android:textColor="#1A2C3E"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalDistance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Km: 0,0"
                        android:textSize="12sp"
                        android:textColor="#1A2C3E"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tempo: 0h 0min"
                        android:textSize="12sp"
                        android:textColor="#1A2C3E"
                        android:textStyle="bold" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEF2F6"
                    android:layout_marginVertical="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Faturamento bruto:"
                        android:textSize="12sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvGrossRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$ 0,00"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Gorjetas:"
                        android:textSize="12sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvTotalTips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$ 0,00"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#00A86B" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reajustes:"
                        android:textSize="12sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvTotalAdjustments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$ 0,00"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#F97316" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Custo total:"
                        android:textSize="12sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvTotalCost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$ 0,00"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#EF4444" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEF2F6"
                    android:layout_marginVertical="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lucro l\u00EDquido:"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A2C3E" />

                    <TextView
                        android:id="@+id/tvNetProfit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$ 0,00"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#00A86B" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvProfitPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% de margem"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginBottom="6dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEF2F6"
                    android:layout_marginVertical="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvRevenuePerKm"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="R\$/km: 0,00"
                        android:textSize="11sp"
                        android:textColor="#5E6F8D"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRevenuePerHour"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="R\$/h: 0,00"
                        android:textSize="11sp"
                        android:textColor="#5E6F8D"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAvgTip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="M\u00E9dia gorjeta: R$ 0,00"
                        android:textSize="11sp"
                        android:textColor="#5E6F8D"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- Corridas Realizadas -->
            <TextView
                android:id="@+id/tvCompletedHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="\u2705 CORRIDAS REALIZADAS"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A2C3E"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/emptyCompleted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nenhuma corrida adicionada hoje."
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCompletedRides"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

            <!-- Card de Adição Manual -->
            <LinearLayout
                android:id="@+id/btnAddManualRide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:background="#F0F9FF"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="\uD83D\uDCA1"
                    android:textSize="18sp"
                    android:background="#E6F7FF"
                    android:padding="6dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sua corrida n\u00E3o est\u00E1 no hist\u00F3rico?"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1A2C3E" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Adicione manualmente uma corrida que n\u00E3o foi detectada"
                        android:textSize="10sp"
                        android:textColor="#6B7280"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="\u2795 Adicionar"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="#00982B"
                    android:paddingHorizontal="16dp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Corridas Disponiveis -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="\uD83D\uDCCB CORRIDAS DISPON\u00CDVEIS"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A2C3E" />

                    <TextView
                        android:id="@+id/tvHistoryInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#5E6F8D" />

                </LinearLayout>

                <!-- Container de filtros -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="#F8F9FE"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="\uD83D\uDD0D FILTROS"
                        android:textSize="11sp"
                        android:textColor="#5E6F8D"
                        android:textStyle="bold" />

                    <!-- Filtro Horário -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/filterMorning"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:paddingHorizontal="12dp"
                            android:gravity="center"
                            android:text="06-12h"
                            android:textSize="11sp"
                            android:textColor="#5E6F8D"
                            android:background="@drawable/pill_unselected"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/filterAfternoon"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:paddingHorizontal="12dp"
                            android:gravity="center"
                            android:text="12-18h"
                            android:textSize="11sp"
                            android:textColor="#5E6F8D"
                            android:background="@drawable/pill_unselected"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/filterEvening"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:paddingHorizontal="12dp"
                            android:gravity="center"
                            android:text="18-00h"
                            android:textSize="11sp"
                            android:textColor="#5E6F8D"
                            android:background="@drawable/pill_unselected"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <!-- Filtro Valor -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/filterValue1"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:paddingHorizontal="12dp"
                            android:gravity="center"
                            android:text="R$ 0-15"
                            android:textSize="11sp"
                            android:textColor="#5E6F8D"
                            android:background="@drawable/pill_unselected"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/filterValue2"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:paddingHorizontal="12dp"
                            android:gravity="center"
                            android:text="R$ 15-30"
                            android:textSize="11sp"
                            android:textColor="#5E6F8D"
                            android:background="@drawable/pill_unselected"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/filterValue3"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:paddingHorizontal="12dp"
                            android:gravity="center"
                            android:text="R$ 30-50"
                            android:textSize="11sp"
                            android:textColor="#5E6F8D"
                            android:background="@drawable/pill_unselected"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/filterValue4"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:paddingHorizontal="12dp"
                            android:gravity="center"
                            android:text="R$ 50+"
                            android:textSize="11sp"
                            android:textColor="#5E6F8D"
                            android:background="@drawable/pill_unselected"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <!-- Filtro Categoria -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\uD83C\uDFF7\uFE0F Categoria"
                            android:textSize="11sp"
                            android:textColor="#5E6F8D"
                            android:layout_marginBottom="4dp" />

                        <com.profitdriving.WrapContentFlowLayout
                            android:id="@+id/filterCategoryContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/filterCategoryAll"
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:paddingHorizontal="12dp"
                                android:gravity="center"
                                android:text="Todas"
                                android:textSize="11sp"
                                android:background="@drawable/pill_selected"
                                android:layout_marginEnd="6dp"
                                android:layout_marginBottom="6dp"
                                android:clickable="true"
                                android:focusable="true" />

                        </com.profitdriving.WrapContentFlowLayout>

                    </LinearLayout>

                    <!-- Limpar Filtros -->
                    <TextView
                        android:id="@+id/btnClearFilters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\u2716 Limpar filtros"
                        android:textSize="10sp"
                        android:textColor="#F87171"
                        android:padding="4dp"
                        android:layout_marginTop="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <TextView
                    android:id="@+id/emptyAvailable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Todas as corridas de hoje j\u00E1 foram adicionadas."
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"
                    android:gravity="center"
                    android:paddingVertical="20dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAvailableRides"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btnLoadMoreAvailable"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="Ver mais corridas"
                    android:textSize="13sp"
                    android:textColor="#1A2C3E"
                    android:textStyle="bold"
                    android:background="#F0F2F8"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true" />

                <ProgressBar
                    android:id="@+id/progressAvailable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_margin="16dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/bottom_nav" />

</LinearLayout>
