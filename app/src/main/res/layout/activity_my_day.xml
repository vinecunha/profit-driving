<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <include layout="@layout/toolbar_default" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:paddingBottom="24dp">

            <!-- ==================================== -->
            <!-- CARD DE NAVEGAÇÃO DE PERÍODO          -->
            <!-- ==================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Botões de modo Dia/Semana/Mês -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/btnModeDay"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="\uD83D\uDCC5 Dia"
                        android:textSize="@dimen/text_size_13"
                        android:textStyle="bold"
                        android:background="@color/primary"
                        android:textColor="@color/text_inverse"
                        android:layout_marginEnd="4dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnModeWeek"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="\uD83D\uDCC6 Semana"
                        android:textSize="@dimen/text_size_13"
                        android:background="@drawable/pill_unselected"
                        android:layout_marginHorizontal="4dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnModeMonth"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="\uD83D\uDCCA M\u00EAs"
                        android:textSize="@dimen/text_size_13"
                        android:background="@drawable/pill_unselected"
                        android:layout_marginStart="4dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- Navegação por período -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/btnPrevPeriod"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="\u25C0"
                        android:textSize="@dimen/text_size_16"
                        android:textColor="@color/text_primary"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tvPeriodTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Carregando..."
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/btnNextPeriod"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="\u25B6"
                        android:textSize="@dimen/text_size_16"
                        android:textColor="@color/text_primary"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- Botão Hoje -->
                <TextView
                    android:id="@+id/btnToday"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Hoje"
                    android:textSize="@dimen/text_size_12"
                    android:textColor="@color/success"
                    android:paddingHorizontal="16dp"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- ==================================== -->
            <!-- CARD DE RESUMO DO PERÍODO             -->
            <!-- ==================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Cabeçalho do resumo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="\uD83D\uDCCA RESUMO"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvPeriodBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="hoje"
                        android:textSize="@dimen/text_size_10"
                        android:textColor="@color/accent"
                        android:layout_marginStart="8dp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Métricas principais em grid 2x2 (duas linhas) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/tvRideCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/text_size_20"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Corridas"
                            android:textSize="@dimen/text_size_10"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/tvTotalDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/text_size_20"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Km"
                            android:textSize="@dimen/text_size_10"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/tvTotalDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0h"
                            android:textSize="@dimen/text_size_20"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Horas"
                            android:textSize="@dimen/text_size_10"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/tvGrossRevenue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$0"
                            android:textSize="@dimen/text_size_20"
                            android:textStyle="bold"
                            android:textColor="@color/success" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Faturamento"
                            android:textSize="@dimen/text_size_10"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Linha de lucro destacada -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bg_surface"
                    android:layout_marginVertical="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="\uD83D\uDCB0 Lucro l\u00EDquido"
                        android:textSize="@dimen/text_size_14"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNetProfit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$ 0,00"
                        android:textSize="@dimen/text_size_18"
                        android:textStyle="bold"
                        android:textColor="@color/success" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvProfitPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0% de margem"
                        android:textSize="@dimen/text_size_11"
                        android:textColor="@color/text_tertiary" />

                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:background="@color/border"
                        android:layout_marginHorizontal="6dp"
                        android:layout_gravity="center" />

                    <TextView
                        android:id="@+id/tvRevenuePerKm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$/km: 0,00"
                        android:textSize="@dimen/text_size_11"
                        android:textColor="@color/text_tertiary" />

                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:background="@color/border"
                        android:layout_marginHorizontal="6dp"
                        android:layout_gravity="center" />

                    <TextView
                        android:id="@+id/tvRevenuePerHour"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$/h: 0,00"
                        android:textSize="@dimen/text_size_11"
                        android:textColor="@color/text_tertiary" />

                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:background="@color/border"
                        android:layout_marginHorizontal="6dp"
                        android:layout_gravity="center" />

                    <TextView
                        android:id="@+id/tvPrediction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="@dimen/text_size_11"
                        android:textColor="@color/accent"
                        android:visibility="gone"
                        android:maxLines="1" />

                </LinearLayout>

                <!-- Botão expandir custos -->
                <TextView
                    android:id="@+id/btnToggleCostDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u25BC Ver detalhes dos custos"
                    android:textSize="@dimen/text_size_11"
                    android:textColor="@color/success"
                    android:paddingTop="12dp"
                    android:clickable="true"
                    android:focusable="true" />

                <LinearLayout
                    android:id="@+id/layoutCostDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ==================================== -->
            <!-- SEÇÃO: CORRIDAS REALIZADAS            -->
            <!-- ==================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="\u2705 CORRIDAS REALIZADAS"
                        android:textSize="@dimen/text_size_13"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvCompletedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="20dp"
                        android:text="0"
                        android:textSize="@dimen/text_size_11"
                        android:textColor="@color/text_inverse"
                        android:background="@color/success"
                        android:paddingHorizontal="8dp"
                        android:gravity="center" />

                </LinearLayout>

                <TextView
                    android:id="@+id/emptyCompleted"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma corrida adicionada."
                    android:textSize="@dimen/text_size_12"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center"
                    android:padding="32dp"
                    android:background="@drawable/card_bg"
                    android:visibility="visible" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCompletedRides"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ==================================== -->
            <!-- CARD: ADICIONAR CORRIDA MANUAL        -->
            <!-- ==================================== -->
            <LinearLayout
                android:id="@+id/btnAddManualRide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/card_bg"
                android:elevation="1dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="\u2795"
                    android:textSize="@dimen/text_size_18"
                    android:background="@color/accent_light"
                    android:padding="6dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Adicionar corrida manual"
                        android:textSize="@dimen/text_size_13"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Corrida n\u00E3o foi detectada?"
                        android:textSize="@dimen/text_size_10"
                        android:textColor="@color/text_tertiary" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="Adicionar"
                    android:textSize="@dimen/text_size_11"
                    android:textColor="@color/text_inverse"
                    android:background="@color/accent"
                    android:paddingHorizontal="12dp" />

            </LinearLayout>

            <!-- ==================================== -->
            <!-- SEÇÃO: CORRIDAS DISPONÍVEIS           -->
            <!-- ==================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="\uD83D\uDCCB CORRIDAS DISPON\u00CDVEIS"
                        android:textSize="@dimen/text_size_13"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvHistoryInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_10"
                        android:textColor="@color/text_tertiary" />

                </LinearLayout>

                <!-- Card de Filtros (colapsável) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:id="@+id/btnToggleFilters">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="\uD83D\uDD0D FILTROS"
                            android:textSize="@dimen/text_size_11"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvFilterToggleIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u25BC"
                            android:textSize="@dimen/text_size_10"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                    <!-- Container de filtros colapsável -->
                    <LinearLayout
                        android:id="@+id/filterContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">

                        <!-- Busca -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/bg_surface"
                            android:padding="8dp"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="\uD83D\uDD0E"
                                android:textSize="@dimen/text_size_12"
                                android:layout_marginEnd="8dp" />

                            <EditText
                                android:id="@+id/etSearchRides"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Buscar por tipo, local..."
                                android:textSize="@dimen/text_size_11"
                                android:background="@null"
                                android:inputType="text"
                                android:maxLines="1" />

                            <TextView
                                android:id="@+id/btnClearSearch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="\u2716"
                                android:textSize="@dimen/text_size_11"
                                android:textColor="@color/text_tertiary"
                                android:padding="4dp"
                                android:visibility="gone" />

                        </LinearLayout>

                        <!-- Horário -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u23F0 Horário"
                            android:textSize="@dimen/text_size_11"
                            android:textColor="@color/text_tertiary"
                            android:layout_marginBottom="6dp" />

                        <LinearLayout
                            android:id="@+id/timeFilterContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp" />

                        <!-- Valor -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\uD83D\uDCB0 Valor"
                            android:textSize="@dimen/text_size_11"
                            android:textColor="@color/text_tertiary"
                            android:layout_marginBottom="6dp" />

                        <LinearLayout
                            android:id="@+id/valueFilterContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp" />

                        <!-- Categoria -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\uD83D\uDE97 Categoria"
                            android:textSize="@dimen/text_size_11"
                            android:textColor="@color/text_tertiary"
                            android:layout_marginBottom="6dp" />

                        <com.profitdriving.WrapContentFlowLayout
                            android:id="@+id/filterCategoryContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp" />

                        <!-- Limpar Filtros -->
                        <TextView
                            android:id="@+id/btnClearFilters"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Limpar filtros"
                            android:textSize="@dimen/text_size_11"
                            android:textColor="@color/metric_bad"
                            android:padding="4dp"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/emptyAvailable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Todas as corridas j\u00E1 foram adicionadas."
                    android:textSize="@dimen/text_size_12"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center"
                    android:padding="32dp"
                    android:background="@drawable/card_bg"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAvailableRides"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btnLoadMoreAvailable"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="Ver mais"
                    android:textSize="@dimen/text_size_12"
                    android:textColor="@color/text_primary"
                    android:background="@color/bg_surface"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true" />

                <ProgressBar
                    android:id="@+id/progressAvailable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_margin="16dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/bottom_nav" />

</LinearLayout>
