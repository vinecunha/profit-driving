<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLogo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CorridaCerta"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1A2C3E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Análise inteligente de corridas"
                    android:textSize="11sp"
                    android:textColor="#8E9AAF"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#F0F2F8"
                android:padding="3dp">

                <TextView
                    android:id="@+id/btnConfigure"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="Parâmetros"
                    android:textSize="12sp"
                    android:textColor="#5E6F8D"
                    android:background="@drawable/toggle_unselected"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:paddingHorizontal="12dp"
                    android:gravity="center"
                    android:text="Card Teste"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/pill_selected"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <TextView
                android:id="@+id/btnClearHistory"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="🗑"
                android:textSize="16sp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Filters + Access Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tvAccessibilityBadge"
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:paddingHorizontal="8dp"
                android:gravity="center"
                android:textSize="10sp"
                android:textColor="#6B7280"
                android:background="#F0F2F8"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="3dp">

                <TextView
                    android:id="@+id/btnFilterToday"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="Hoje"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/pill_selected"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnFilter7d"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="7 dias"
                    android:textSize="11sp"
                    android:textColor="#8E9AAF"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:id="@+id/btnFilter30d"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="30 dias"
                    android:textSize="11sp"
                    android:textColor="#8E9AAF"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:id="@+id/btnFilterAll"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="Tudo"
                    android:textSize="11sp"
                    android:textColor="#8E9AAF"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="56sp"
                android:gravity="center"
                android:text="🚗" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nenhuma corrida ainda"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:gravity="center"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Abra o Uber Driver ou 99 Driver\ne aguarde uma solicitação de corrida.\nO card aparecerá automaticamente."
                android:textSize="14sp"
                android:textColor="#888888"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingHorizontal="12dp"
            android:paddingBottom="88dp" />

    </LinearLayout>

    <!-- FAB (visibility controlled by code) -->
    <TextView
        android:id="@+id/btnRadar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:textSize="24sp"
        android:text="📡"
        android:background="@drawable/pill_selected"
        android:elevation="6dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

</FrameLayout>
