<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F8">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:background="#2E7D32">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_launcher"
            android:contentDescription=""
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CorridaCerta"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/btnClearHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Limpar"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:paddingVertical="4dp"
            android:paddingHorizontal="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

    <!-- Navigation Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/btnPermissions"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Permissões"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/pill_unselected"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnConfigure"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Parâmetros"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/pill_unselected"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnPreview"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Card Teste"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/pill_unselected"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnAnalysis"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Análise"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:layout_marginStart="4dp"
            android:background="@drawable/pill_unselected"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Filter Pills + Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/btnFilterToday"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Hoje"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:background="@drawable/pill_selected"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnFilter7d"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="7 dias"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:background="@drawable/pill_unselected"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/btnFilter30d"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="30 dias"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:background="@drawable/pill_unselected"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/btnFilterAll"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Tudo"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:background="@drawable/pill_unselected"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvAccessibilityBadge"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:paddingHorizontal="10dp"
            android:gravity="center"
            android:textSize="10sp"
            android:background="@drawable/inner_card_bg"
            android:textColor="#6B7280" />

    </LinearLayout>

    <!-- Status Text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#9CA3AF"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:lineSpacingExtra="2dp" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚗"
            android:textSize="56sp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nenhuma corrida ainda"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:gravity="center"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Abra o Uber Driver ou 99 Driver\ne aguarde uma solicitação de corrida.\nO card aparecerá automaticamente."
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Old emptyText (legacy) -->
    <TextView
        android:id="@+id/emptyText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="#9CA3AF"
        android:lineSpacingExtra="5dp"
        android:text="Nenhuma corrida capturada ainda.\nAtive o serviço de acessibilidade\npara monitorar Uber e 99."
        android:visibility="gone" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp" />

</LinearLayout>
