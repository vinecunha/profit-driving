<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include layout="@layout/toolbar_default" />

        <!-- Filters -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp"
            android:layout_marginTop="2dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="3dp">

                <TextView
                    android:id="@+id/btnFilterToday"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="Hoje"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/pill_selected"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnFilter7d"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="7 dias"
                    android:textSize="11sp"
                    android:textColor="#8E9AAF"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:id="@+id/btnFilter30d"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="30 dias"
                    android:textSize="11sp"
                    android:textColor="#8E9AAF"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:id="@+id/btnFilterAll"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:text="Tudo"
                    android:textSize="11sp"
                    android:textColor="#8E9AAF"
                    android:background="@drawable/pill_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- Filter toggle -->
            <LinearLayout
                android:id="@+id/btnFilterToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="3dp"
                android:layout_marginTop="4dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="Filtros"
                    android:textSize="13sp"
                    android:textColor="#1A2C3E"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFilterToggleIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u25BC"
                    android:textSize="10sp"
                    android:textColor="#8E9AAF" />

            </LinearLayout>

            <!-- Collapsible filter container -->
            <LinearLayout
                android:id="@+id/filterContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Service type filter -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/serviceTypeContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="3dp">

                        <TextView
                            android:id="@+id/btnFilterAllTypes"
                            android:layout_width="wrap_content"
                            android:layout_height="26dp"
                            android:paddingHorizontal="10dp"
                            android:gravity="center"
                            android:text="Todas"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:background="@drawable/pill_selected"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                </HorizontalScrollView>

                <!-- Score filter (Boa / Média / Ruim) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:padding="3dp">

                    <TextView
                        android:id="@+id/btnFilterAllScores"
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:paddingHorizontal="10dp"
                        android:gravity="center"
                        android:text="Todas"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:background="@drawable/pill_selected"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnFilterGood"
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:paddingHorizontal="10dp"
                        android:gravity="center"
                        android:text="\u2705 Boa"
                        android:textSize="11sp"
                        android:textColor="#8E9AAF"
                        android:background="@drawable/pill_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/btnFilterMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:paddingHorizontal="10dp"
                        android:gravity="center"
                        android:text="\u26A0\uFE0F M\u00E9dia"
                        android:textSize="11sp"
                        android:textColor="#8E9AAF"
                        android:background="@drawable/pill_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/btnFilterBad"
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:paddingHorizontal="10dp"
                        android:gravity="center"
                        android:text="\u274C Ruim"
                        android:textSize="11sp"
                        android:textColor="#8E9AAF"
                        android:background="@drawable/pill_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="56sp"
                android:gravity="center"
                android:text="🚗" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nenhuma corrida ainda"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:gravity="center"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Abra o Uber Driver ou 99 Driver\ne aguarde uma solicitação de corrida.\nO card aparecerá automaticamente."
                android:textSize="14sp"
                android:textColor="#888888"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- RecyclerView + Load More -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingHorizontal="12dp"
                android:paddingBottom="12dp" />

            <TextView
                android:id="@+id/btnLoadMore"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="Ver mais"
                android:textSize="13sp"
                android:textColor="#1A2C3E"
                android:textStyle="bold"
                android:background="#F0F2F8"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <include layout="@layout/bottom_nav" />

    </LinearLayout>

    <!-- FAB (visibility controlled by code) -->
    <TextView
        android:id="@+id/btnRadar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="80dp"
        android:gravity="center"
        android:textSize="24sp"
        android:text="📡"
        android:background="@drawable/pill_selected"
        android:elevation="6dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

</FrameLayout>
