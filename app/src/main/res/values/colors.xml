<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================ -->
    <!-- PRIMÁRIA (neutro profissional)               -->
    <!-- ============================================ -->
    <color name="primary">#1E293B</color>        <!-- Slate 800 - toolbar, headers -->
    <color name="primary_dark">#0F172A</color>   <!-- Slate 900 - versão escura -->
    <color name="primary_light">#F1F5F9</color>  <!-- Slate 100 - fundos suaves -->

    <!-- ============================================ -->
    <!-- ACENTO (azul para ações)                    -->
    <!-- ============================================ -->
    <color name="accent">#2563EB</color>          <!-- Azul 600 - botões, links -->
    <color name="accent_dark">#1D4ED8</color>     <!-- Azul 700 -->
    <color name="accent_light">#DBEAFE</color>    <!-- Azul 100 - fundo de destaque -->

    <!-- ============================================ -->
    <!-- DECISÕES (semântica universal)              -->
    <!-- ============================================ -->
    <!-- ACEITAR / BOM / LUCRO -->
    <color name="success">#059669</color>         <!-- Esmeralda 600 -->
    <color name="success_bg">#D1FAE5</color>      <!-- Esmeralda 100 -->
    <color name="success_text">#064E3B</color>    <!-- Esmeralda 900 -->

    <!-- ANALISAR / MÉDIO / ATENÇÃO -->
    <color name="warning">#D97706</color>         <!-- Âmbar 600 -->
    <color name="warning_bg">#FEF3C7</color>      <!-- Âmbar 100 -->
    <color name="warning_text">#78350F</color>    <!-- Âmbar 900 -->

    <!-- RECUSAR / RUIM / PREJUÍZO -->
    <color name="error">#DC2626</color>           <!-- Vermelho 600 -->
    <color name="error_bg">#FEE2E2</color>        <!-- Vermelho 100 -->
    <color name="error_text">#991B1B</color>      <!-- Vermelho 900 -->

    <!-- ============================================ -->
    <!-- CARD FLUTUANTE (fundo escuro para contraste)-->
    <!-- ============================================ -->
    <color name="overlay_bg">#0F172A</color>      <!-- Slate 900 -->
    <color name="overlay_surface">#1E293B</color> <!-- Slate 800 -->
    <color name="overlay_border">#334155</color>  <!-- Slate 700 -->
    <color name="overlay_text_primary">#F8FAFC</color>  <!-- Slate 50 -->
    <color name="overlay_text_secondary">#94A3B8</color> <!-- Slate 400 -->

    <!-- Valores no card flutuante (contrastes claros) -->
    <color name="overlay_success">#34D399</color> <!-- Esmeralda 400 -->
    <color name="overlay_warning">#FBBF24</color> <!-- Âmbar 400 -->
    <color name="overlay_error">#F87171</color>   <!-- Vermelho 400 -->

    <!-- ============================================ -->
    <!-- SISTEMA (tema claro)                        -->
    <!-- ============================================ -->
    <!-- Fundos -->
    <color name="bg_screen">#121212</color>       <!-- Dark - fundo principal (alinhado ao header) -->
    <color name="bg_card">#1E1E1E</color>         <!-- Dark elevado - cards, superfícies -->
    <color name="bg_surface">#2A2A2A</color>      <!-- Dark médio - áreas secundárias -->

    <!-- Bordas e divisores -->
    <color name="border">#333333</color>          <!-- Dark borda -->
    <color name="border_light">#2A2A2A</color>    <!-- Dark borda leve -->
    <color name="border_focus">#2563EB</color>    <!-- Azul 600 -->

    <!-- Textos -->
    <color name="text_primary">#F1F5F9</color>    <!-- Slate 100 - claro -->
    <color name="text_secondary">#94A3B8</color>  <!-- Slate 400 -->
    <color name="text_tertiary">#64748B</color>   <!-- Slate 500 -->
    <color name="text_disabled">#475569</color>   <!-- Slate 600 -->
    <color name="text_inverse">#0F172A</color>    <!-- Slate 900 - escuro -->

    <!-- Ícones -->
    <color name="icon_primary">#94A3B8</color>    <!-- Slate 400 -->
    <color name="icon_secondary">#64748B</color>  <!-- Slate 500 -->
    <color name="icon_accent">#2563EB</color>     <!-- Azul 600 -->

    <!-- Preços -->
    <color name="text_price">@color/text_primary</color>
    <color name="text_price_positive">@color/success</color>
    <color name="text_price_negative">@color/error</color>

    <!-- ============================================ -->
    <!-- TIPOS DE SERVIÇO (opcional, legível)        -->
    <!-- ============================================ -->
    <color name="service_uberx">#1E293B</color>   <!-- Slate 800 -->
    <color name="service_black">#111827</color>   <!-- Slate 900 -->
    <color name="service_comfort">#2563EB</color> <!-- Azul 600 -->
    <color name="service_moto">#059669</color>    <!-- Esmeralda 600 -->
    <color name="service_delivery">#D97706</color> <!-- Âmbar 600 -->

    <!-- ============================================ -->
    <!-- COMPATIBILIDADE (nomes antigos)             -->
    <!-- ============================================ -->
    <color name="colorPrimary">@color/primary</color>
    <color name="colorPrimaryDark">@color/primary_dark</color>
    <color name="colorAccent">@color/accent</color>

    <color name="pill_active_bg">@color/accent</color>
    <color name="pill_active_text">#FFFFFF</color>
    <color name="pill_inactive_bg">#2A2A2A</color>
    <color name="pill_inactive_text">@color/text_secondary</color>

    <color name="rating_good_bg">@color/success_bg</color>
    <color name="rating_good_text">@color/success_text</color>
    <color name="rating_medium_bg">@color/warning_bg</color>
    <color name="rating_medium_text">@color/warning_text</color>
    <color name="rating_bad_bg">@color/error_bg</color>
    <color name="rating_bad_text">@color/error_text</color>

    <color name="card_border_good">@color/success</color>
    <color name="card_border_medium">@color/warning</color>
    <color name="card_border_bad">@color/error</color>
</resources>
