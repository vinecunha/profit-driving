<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================ -->
    <!-- CORES PRIMÁRIAS (Toolbar, headers)           -->
    <!-- ============================================ -->
    <color name="primary">#1E293B</color>        <!-- Slate 800 -->
    <color name="primary_dark">#0F172A</color>   <!-- Slate 900 -->
    <color name="primary_light">#F1F5F9</color>  <!-- Slate 100 -->

    <!-- ============================================ -->
    <!-- CORES DE AÇÃO (Botões, links)               -->
    <!-- ============================================ -->
    <color name="accent">#2563EB</color>          <!-- Azul 600 -->
    <color name="accent_dark">#1D4ED8</color>     <!-- Azul 700 -->
    <color name="accent_light">#DBEAFE</color>    <!-- Azul 100 -->

    <!-- ============================================ -->
    <!-- DECISÃO ACEITAR / BOA / LUCRO               -->
    <!-- ============================================ -->
    <color name="success">#00A86B</color>         <!-- Verde primário -->
    <color name="success_bg">#D1FAE5</color>      <!-- Fundo verde claro -->
    <color name="success_text">#064E3B</color>    <!-- Texto verde escuro -->
    <color name="success_border">#00A86B</color>  <!-- Borda verde -->

    <!-- ============================================ -->
    <!-- DECISÃO ANALISAR / MÉDIA / ATENÇÃO          -->
    <!-- ============================================ -->
    <color name="warning">#F97316</color>         <!-- Laranja primário -->
    <color name="warning_bg">#FEF3C7</color>      <!-- Fundo laranja claro -->
    <color name="warning_text">#92400E</color>    <!-- Texto laranja escuro -->
    <color name="warning_border">#F97316</color>  <!-- Borda laranja -->

    <!-- ============================================ -->
    <!-- DECISÃO RECUSAR / RUIM / PREJUÍZO           -->
    <!-- ============================================ -->
    <color name="error">#DC2626</color>           <!-- Vermelho primário -->
    <color name="error_bg">#FEE2E2</color>        <!-- Fundo vermelho claro -->
    <color name="error_text">#991B1B</color>      <!-- Texto vermelho escuro -->
    <color name="error_border">#DC2626</color>    <!-- Borda vermelha -->

    <!-- ============================================ -->
    <!-- VALORES DE MÉTRICAS (R$/km, R$/h, R$/min)  -->
    <!-- ============================================ -->
    <color name="metric_good">#4ADE80</color>     <!-- Verde claro -->
    <color name="metric_medium">#FB923C</color>   <!-- Laranja claro -->
    <color name="metric_bad">#F87171</color>      <!-- Vermelho claro -->

    <!-- ============================================ -->
    <!-- CARD FLUTUANTE (fundo escuro)               -->
    <!-- ============================================ -->
    <color name="overlay_bg">#0F172A</color>      <!-- Slate 900 -->
    <color name="overlay_surface">#1E293B</color> <!-- Slate 800 -->
    <color name="overlay_border">#334155</color>  <!-- Slate 700 -->
    <color name="overlay_text_primary">#F8FAFC</color>
    <color name="overlay_text_secondary">#94A3B8</color>
    <color name="overlay_success">#4ADE80</color>
    <color name="overlay_warning">#F97316</color>
    <color name="overlay_error">#F87171</color>

    <!-- ============================================ -->
    <!-- FUNDOS E SUPERFÍCIES                        -->
    <!-- ============================================ -->
    <color name="bg_screen">#F8FAFC</color>       <!-- Slate 50 -->
    <color name="bg_card">#FFFFFF</color>         <!-- Branco -->
    <color name="bg_surface">#F1F5F9</color>      <!-- Slate 100 -->

    <!-- ============================================ -->
    <!-- BORDAS E DIVISORES                          -->
    <!-- ============================================ -->
    <color name="border">#E2E8F0</color>          <!-- Slate 200 -->
    <color name="border_light">#F1F5F9</color>    <!-- Slate 100 -->
    <color name="border_focus">#2563EB</color>    <!-- Azul 600 -->

    <!-- ============================================ -->
    <!-- TEXTOS                                      -->
    <!-- ============================================ -->
    <color name="text_primary">#0F172A</color>    <!-- Slate 900 -->
    <color name="text_secondary">#475569</color>  <!-- Slate 600 -->
    <color name="text_tertiary">#94A3B8</color>   <!-- Slate 400 -->
    <color name="text_disabled">#CBD5E1</color>   <!-- Slate 300 -->
    <color name="text_inverse">#FFFFFF</color>

    <!-- ============================================ -->
    <!-- PREÇOS (Compatibilidade)                     -->
    <!-- ============================================ -->
    <color name="text_price">@color/text_primary</color>
    <color name="text_price_positive">@color/success</color>
    <color name="text_price_negative">@color/error</color>

    <!-- ============================================ -->
    <!-- ÍCONES                                      -->
    <!-- ============================================ -->
    <color name="icon_primary">#475569</color>
    <color name="icon_secondary">#94A3B8</color>
    <color name="icon_accent">#2563EB</color>

    <!-- ============================================ -->
    <!-- TIPOS DE SERVIÇO                            -->
    <!-- ============================================ -->
    <color name="service_uberx">#1E293B</color>
    <color name="service_black">#111827</color>
    <color name="service_comfort">#2563EB</color>
    <color name="service_moto">#00A86B</color>
    <color name="service_delivery">#F97316</color>

    <!-- ============================================ -->
    <!-- COMPATIBILIDADE (nomes antigos)             -->
    <!-- ============================================ -->
    <color name="colorPrimary">@color/primary</color>
    <color name="colorPrimaryDark">@color/primary_dark</color>
    <color name="colorAccent">@color/accent</color>

    <color name="pill_active_bg">@color/accent</color>
    <color name="pill_active_text">#FFFFFF</color>
    <color name="pill_inactive_bg">#F1F5F9</color>
    <color name="pill_inactive_text">@color/text_secondary</color>

    <color name="rating_good_bg">@color/success_border</color>
    <color name="rating_good_text">@color/success_text</color>
    <color name="rating_medium_bg">@color/warning_border</color>
    <color name="rating_medium_text">@color/warning_text</color>
    <color name="rating_bad_bg">@color/error_border</color>
    <color name="rating_bad_text">@color/error_text</color>

    <color name="card_border_good">@color/success_border</color>
    <color name="card_border_medium">@color/warning_border</color>
    <color name="card_border_bad">@color/error_border</color>
</resources>