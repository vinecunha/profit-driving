<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="PillSelected">
        <item name="android:background">@drawable/pill_selected</item>
        <item name="android:textColor">@color/pill_active_text</item>
        <item name="android:textSize">12sp</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">10dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="PillUnselected">
        <item name="android:background">@drawable/pill_unselected</item>
        <item name="android:textColor">@color/pill_inactive_text</item>
        <item name="android:textSize">12sp</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">10dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
</resources>
